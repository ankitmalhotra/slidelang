# Slidelang — environment configuration
# Copy this file to .env and fill in ONE provider below.
# Leave everything commented to use the no-key template planner.
# .env is git-ignored — never commit real keys.

# --- Anthropic / Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5      # optional; this is the default (cheapest)

# --- OpenAI ---
# OPENAI_API_KEY=sk-...

# --- Ollama (local, free, no key) ---
# OLLAMA_HOST=http://localhost:11434

# --- Force a specific provider (optional) ---
# SLIDELANG_PROVIDER=template           # template | claude | openai | ollama
